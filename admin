<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - ELLE Maroquinerie</title>
  <style>
    body {
      font-family: "Poppins", sans-serif;
      background: #f9f9f9;
      margin: 0; padding: 0;
      display: flex; flex-direction: column; align-items: center;
    }
    header {
      background: #fff;
      width: 100%; box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 20px; position: sticky; top: 0; z-index: 100;
    }
    header img { height: 40px; }
    header h1 { font-size: 1.2rem; margin: 0; }
    header a {
      background: #000; color: #fff; text-decoration: none;
      padding: 8px 14px; border-radius: 8px;
    }
    main { width: 95%; max-width: 600px; margin-top: 20px; }

    .product-list { margin-bottom: 20px; }
    .product-item {
      background: #fff; border-radius: 12px; box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      padding: 12px; margin-bottom: 10px;
      display: flex; justify-content: space-between; align-items: center;
    }

    button {
      background: #000; color: #fff; border: none; border-radius: 8px;
      padding: 8px 12px; cursor: pointer;
    }
    button:hover { opacity: 0.85; }

    form {
      background: #fff; border-radius: 12px; padding: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1); display: none;
      flex-direction: column; gap: 10px;
    }
    input, textarea {
      width: 100%; padding: 8px;
      border: 1px solid #ccc; border-radius: 8px;
      font-size: 1rem;
    }

    .image-drop {
      border: 2px dashed #aaa; border-radius: 12px;
      padding: 20px; text-align: center;
      color: #777; cursor: pointer;
    }
    .image-drop img {
      max-width: 100px; margin-top: 10px; border-radius: 8px;
    }

    .preview-card {
      display: none; background: #fff; border-radius: 12px;
      padding: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.2);
      margin-top: 15px; text-align: center;
    }
    .preview-card img { max-width: 150px; border-radius: 8px; }

    @media(max-width:600px){
      header h1 { font-size: 1rem; }
      button, input, textarea { font-size: 0.9rem; }
    }
  </style>
</head>
<body>
  <header>
    <img src="assets/Logo.png" alt="Logo">
    <h1>Espace Admin</h1>
    <a href="index.html">← Retour</a>
  </header>

  <main>
    <div class="product-list" id="productList"></div>

    <button id="addBtn">➕ Ajouter un sac</button>

    <form id="productForm">
      <h3 id="formTitle">Ajouter un nouveau sac</h3>
      <div class="image-drop" id="imageDrop">Déposez une image ou cliquez ici</div>
      <input type="file" id="imageInput" accept="image/*" hidden>
      <input type="text" id="nameInput" placeholder="Nom du sac" required>
      <textarea id="descInput" placeholder="Description" required></textarea>
      <input type="number" id="priceInput" placeholder="Prix (€)" required>
      <button type="button" id="previewBtn">👁️ Prévisualiser</button>
      <button type="submit">💾 Enregistrer</button>
      <button type="button" id="cancelBtn">❌ Annuler</button>
    </form>

    <div class="preview-card" id="previewCard">
      <h3 id="prevName"></h3>
      <img id="prevImg" alt="aperçu">
      <p id="prevDesc"></p>
      <p><strong id="prevPrice"></strong> €</p>
    </div>
  </main>

  <script>
    const productList = document.getElementById('productList');
    const addBtn = document.getElementById('addBtn');
    const productForm = document.getElementById('productForm');
    const previewCard = document.getElementById('previewCard');
    const imageDrop = document.getElementById('imageDrop');
    const imageInput = document.getElementById('imageInput');

    let currentImg = '';

    // Chargement initial
    const products = JSON.parse(localStorage.getItem('products') || '[]');
    refreshList();

    addBtn.addEventListener('click', () => {
      productForm.style.display = 'flex';
      addBtn.style.display = 'none';
    });

    imageDrop.addEventListener('click', () => imageInput.click());
    imageInput.addEventListener('change', e => handleImage(e.target.files[0]));

    imageDrop.addEventListener('dragover', e => { e.preventDefault(); imageDrop.style.borderColor = '#000'; });
    imageDrop.addEventListener('dragleave', e => imageDrop.style.borderColor = '#aaa');
    imageDrop.addEventListener('drop', e => {
      e.preventDefault();
      imageDrop.style.borderColor = '#aaa';
      handleImage(e.dataTransfer.files[0]);
    });

    function handleImage(file) {
      const reader = new FileReader();
      reader.onload = e => {
        currentImg = e.target.result;
        imageDrop.innerHTML = `<img src="${currentImg}" alt="preview">`;
      };
      reader.readAsDataURL(file);
    }

    document.getElementById('previewBtn').addEventListener('click', () => {
      previewCard.style.display = 'block';
      document.getElementById('prevName').textContent = document.getElementById('nameInput').value;
      document.getElementById('prevDesc').textContent = document.getElementById('descInput').value;
      document.getElementById('prevPrice').textContent = document.getElementById('priceInput').value;
      document.getElementById('prevImg').src = currentImg;
    });

    productForm.addEventListener('submit', e => {
      e.preventDefault();
      const newProduct = {
        name: document.getElementById('nameInput').value,
        desc: document.getElementById('descInput').value,
        price: document.getElementById('priceInput').value,
        img: currentImg
      };
      products.push(newProduct);
      localStorage.setItem('products', JSON.stringify(products));
      productForm.reset();
      currentImg = '';
      imageDrop.innerHTML = 'Déposez une image ou cliquez ici';
      previewCard.style.display = 'none';
      productForm.style.display = 'none';
      addBtn.style.display = 'block';
      refreshList();
    });

    document.getElementById('cancelBtn').addEventListener('click', () => {
      productForm.reset();
      currentImg = '';
      productForm.style.display = 'none';
      addBtn.style.display = 'block';
      previewCard.style.display = 'none';
    });

    function refreshList() {
      productList.innerHTML = '';
      products.forEach((p, i) => {
        const div = document.createElement('div');
        div.className = 'product-item';
        div.innerHTML = `
          <span><strong>${p.name}</strong> - ${p.price} €</span>
          <button onclick="deleteProduct(${i})">🗑️ Supprimer</button>
        `;
        productList.appendChild(div);
      });
    }

    function deleteProduct(i) {
      products.splice(i, 1);
      localStorage.setItem('products', JSON.stringify(products));
      refreshList();
    }
  </script>
</body>
</html>
